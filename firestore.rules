rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false;
    }

    match /magnetRecipients2026/{employeeId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['name', 'nameEn', 'rsn', 'hub', 'status', 'proxy', 'receivedAt'])
        && request.resource.data.name is string
        && request.resource.data.nameEn is string
        && request.resource.data.rsn is string
        && request.resource.data.hub is string
        && request.resource.data.status in ['รับแล้ว', 'ยังไม่ได้รับ']
        && request.resource.data.proxy is string;

      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'proxy', 'receivedAt'])
        && (
          (resource.data.status == 'ยังไม่ได้รับ'
            && request.resource.data.status == 'รับแล้ว'
            && request.resource.data.proxy is string
            && request.resource.data.receivedAt == request.time)
          ||
          (isAdmin()
            && request.resource.data.status == 'ยังไม่ได้รับ'
            && request.resource.data.proxy == ''
            && request.resource.data.receivedAt == null)
        );

      allow delete: if isAdmin();
    }
  }
}
