rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /magnetRecipients2026/{employeeId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['name', 'status', 'proxy', 'receivedAt'])
        && request.resource.data.name is string
        && request.resource.data.status in ['รับแล้ว', 'ยังไม่ได้รับ']
        && request.resource.data.proxy is string;

      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'proxy', 'receivedAt'])
        && resource.data.status == 'ยังไม่ได้รับ'
        && request.resource.data.status == 'รับแล้ว'
        && request.resource.data.proxy is string
        && request.resource.data.receivedAt == request.time;

      allow delete: if false;
    }
  }
}
